{
  "name": "libs-user-api-client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "./libs/libs-user-api-client/src",
  "targets": {
    "generate": {
      "executor": "@jnxplus/nx-gradle:run-task",
      "outputs": ["{projectRoot}/generated"],
      "inputs": [
        "{workspaceRoot}/libs/api-specs/user-service.openapi.yaml"
      ],
      "options": {
        "task": "openApiGenerate"
      },
      "cache": true
    },
    "build": {
      "executor": "@jnxplus/nx-gradle:run-task",
      "outputs": ["{projectRoot}/build"],
      "options": {
        "task": "jar"
      }
    },
    "test": {
      "executor": "@jnxplus/nx-gradle:run-task",
      "options": {
        "task": "test"
      }
    }
  },
  "tags": []
}
