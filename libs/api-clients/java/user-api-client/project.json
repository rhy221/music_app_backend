{
  "name": "user-api-client",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/api-clients/java/user-api-client/src",
  "targets": {
    "generate": {
      "executor": "@jnxplus/nx-gradle:run-task",
      "outputs": ["{projectRoot}/generated"],
      "inputs": [
        "{workspaceRoot}/libs/api-specs/user-service.openapi.yaml"
      ],
      "options": {
        "projectPath": ":user-api-client",
        "task": "openApiGenerate"
      },
      "cache": true      
    },
    "build": {
      "executor": "@jnxplus/nx-gradle:run-task",
      "outputs": ["{projectRoot}/build"],
      "options": {
        "projectPath": ":user-api-client",
        "task": "jar"        
      }
    },
    "test": {
      "executor": "@jnxplus/nx-gradle:run-task",
      "options": {
        "projectPath": ":user-api-client",
        "task": "test"
      }      
    }
  },
  "tags": []
}
