{
  "name": "upload-api-client",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/api-clients/go/upload-api-client",
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/generated"],
      "inputs": [
        "{workspaceRoot}/libs/api-specs/upload-service.openapi.yaml",
        "{projectRoot}/oapi-codegen.yaml"
      ],
      "options": {
        "command": "go run github.com/oapi-codegen/oapi-codegen/v2/cmd/oapi-codegen@latest --config oapi-codegen.yaml ../../../api-specs/upload-service.openapi.yaml",
        "cwd": "{projectRoot}"
      },
      "cache": true
    }
  },
  "tags": []
}
