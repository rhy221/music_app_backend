{
  "name": "recommend-api-client",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "libs/api-clients/python/recommend-api-client/libs/recommend_api_client",
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/generated"],
      "inputs": [
        "{workspaceRoot}/libs/api-specs/recommend-service.openapi.yaml",
        "{projectRoot}/openapi-python-client-config.yaml"
      ],
      "options": {
        "command": ".venv\\Scripts\\openapi-python-client generate --path ../../../api-specs/recommend-service.openapi.yaml --config openapi-python-client-config.yaml --output-path ./generated --meta none --overwrite",
        "cwd": "{projectRoot}"
      },
      "cache": true
    },
    "lock": {
      "executor": "@nxlv/python:lock",
      "options": {
        "update": false
      }
    },
    "sync": {
      "executor": "@nxlv/python:sync",
      "options": {}
    },
    "add": {
      "executor": "@nxlv/python:add",
      "options": {}
    },
    "update": {
      "executor": "@nxlv/python:update",
      "options": {}
    },
    "remove": {
      "executor": "@nxlv/python:remove",
      "options": {}
    },
    "build": {
      "executor": "@nxlv/python:build",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "outputPath": "{projectRoot}/dist",
        "publish": false,
        "lockedVersions": true,
        "bundleLocalDependencies": true
      },
      "cache": true
    },
    "lint": {
      "executor": "@nxlv/python:flake8",
      "outputs": ["{workspaceRoot}/reports/{projectRoot}/pylint.txt"],
      "options": {
        "outputFile": "reports/{projectRoot}/pylint.txt"
      },
      "cache": true
    },
    "test": {
      "executor": "@nxlv/python:run-commands",
      "outputs": [
        "{workspaceRoot}/reports/{projectRoot}/unittests",
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "command": "poetry run pytest tests/",
        "cwd": "{projectRoot}"
      },
      "cache": true
    },
    "install": {
      "executor": "@nxlv/python:install",
      "options": {
        "silent": false,
        "args": "",
        "cacheDir": ".cache/pypoetry",
        "verbose": false,
        "debug": false
      }
    }
  },
  "tags": [],
  "release": {
    "version": {
      "versionActions": "@nxlv/python/release/version-actions"
    }
  }
}
