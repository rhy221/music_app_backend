PORT=8084
SERVICE_NAME=streaming-service
LOG_LEVEL=debug

# PostgreSQL — full connection string
DATABASE_URL=postgres://music_admin:music_pass@localhost:5432/streaming_db?sslmode=disable

# RabbitMQ — full connection string
RABBIT_URL=amqp://music_admin:music_pass@localhost:5672/music

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=music_admin
MINIO_SECRET_KEY=music_pass
MINIO_USE_SSL=false

# Redis — full connection string
REDIS_URL=redis://:music_pass@localhost:6379

CATALOG_SERVICE_URL=http://localhost:8082

# Must match JWT_SECRET in all other services
JWT_SECRET=change-me-in-production-min-32-chars
