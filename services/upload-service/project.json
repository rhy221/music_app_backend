{
  "name": "upload-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "services/upload-service",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go run .",
        "cwd": "{projectRoot}",
        "envFile": "{projectRoot}/.env"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "go build -o dist/upload-service .",
        "cwd": "{projectRoot}"
      },
      "cache": true
    },
    "migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "migrate -path internal/db/migrations -database \"$DATABASE_URL\" up",
        "cwd": "{projectRoot}"
      }
    },
    "migrate:down": {
      "executor": "nx:run-commands",
      "options": {
        "command": "migrate -path internal/db/migrations -database \"$DATABASE_URL\" down 1",
        "cwd": "{projectRoot}"
      }
    }
  },
  "tags": []
}
