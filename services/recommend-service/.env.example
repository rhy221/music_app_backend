PORT=8000

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=music_pass

# Redis — full connection string
REDIS_URL=redis://:music_pass@localhost:6379/0

# RabbitMQ — full connection string
RABBITMQ_URL=amqp://music_admin:music_pass@localhost:5672/music

# Must match JWT_SECRET in all other services
JWT_SECRET=change-me-in-production-min-32-chars

# Cache TTL (seconds)
REC_CACHE_TTL=1800
DISCOVER_CACHE_TTL=604800
COLD_START_THRESHOLD=10
