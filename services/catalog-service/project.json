{
  "name": "catalog-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "services/catalog-service/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@jnxplus/nx-gradle:run-task",
      "outputs": ["{projectRoot}/build"],
      "options": {
        "task": "build",
        "projectPath": ":services:catalog-service"
      }
    },
    "serve": {
      "executor": "@jnxplus/nx-gradle:run-task",
      "options": {
        "task": "bootRun",
        "projectPath": ":services:catalog-service"
      }
    },
    "test": {
      "executor": "@jnxplus/nx-gradle:run-task",
      "options": {
        "task": "test",
        "projectPath": ":services:catalog-service"
      }
    },
    "docker-build": {
    "executor": "nx:run-commands",
    "options": {
      "commands": [
        "docker build -t music-catalog-service:latest -f services/catalog-service/Dockerfile ."
      ]
    }
  }
  }
}
