# =============================================================================
# Music App — Environment Variables Template
# Copy to .env and fill in values for local development.
# Never commit .env files with real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Shared secret — MUST be the same value across ALL services
# Min 32 characters, use: openssl rand -base64 32
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-in-production-min-32-chars

# -----------------------------------------------------------------------------
# PostgreSQL (one cluster, separate databases per service)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=music_admin
DB_PASSWORD=music_pass

# Per-service database names (used in application.yml via DB_NAME)
# user-service    → user_db
# catalog-service → catalog_db
# playlist-service → playlist_db
# upload-service  → upload_db      (used via DATABASE_URL, see service .env)
# streaming-service → streaming_db (used via DATABASE_URL, see service .env)

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=music_pass

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=music_admin
RABBITMQ_PASSWORD=music_pass
RABBITMQ_VHOST=music

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=music_admin
MINIO_SECRET_KEY=music_pass

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Service URLs (used by services that call each other)
# -----------------------------------------------------------------------------
CATALOG_SERVICE_URL=http://localhost:8082
USER_SERVICE_URL=http://localhost:8081

# -----------------------------------------------------------------------------
# user-service — Google OAuth2
# -----------------------------------------------------------------------------
GOOGLE_TOKEN_INFO_URL=https://oauth2.googleapis.com/tokeninfo

# -----------------------------------------------------------------------------
# search-service — Elasticsearch
# -----------------------------------------------------------------------------
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# -----------------------------------------------------------------------------
# notification-service — MongoDB + SMTP
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://music_admin:music_pass@localhost:27017/notifications?authSource=admin

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@musicapp.com

# -----------------------------------------------------------------------------
# recommend-service — Neo4j
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=music_pass
